# Delx MCP server environment (EXAMPLE)
#
# Prefer using the repo-root `.env` + `.env.example`.
# This file exists for convenience when running the MCP server standalone from
# inside `delx-mcp-server/`.

# Wallet (public address)
DELX_WALLET=0x0000000000000000000000000000000000000000

# LLM (optional) — GPT-5.6 recovery reasoning with deterministic/provider fallbacks
LLM_PROVIDER=openai           # "openai" | "openrouter" | "gemini"
LLM_ENABLED=false             # master switch
LLM_TRIAGE_ENABLED=true       # true = only use LLM when depth signals present (recommended)
LLM_ALLOWED_TOOLS=reflect,process_failure,get_recovery_action_plan,express_feelings,get_affirmation,refine_soul_document
# comma-separated tool allowlist. "" or "*" = all wired tools.
LLM_AUDIT_ENABLED=false      # opt-in audit trail for successful LLM generations
LLM_AUDIT_PATH=state/llm_responses.jsonl

# OpenAI Responses API (recommended recovery engine)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Gemini direct (free tier via AI Studio: 1500 req/day)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (paid or :free models — fallback/alternative provider)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2.5

# x402 Payment Facilitator
FACILITATOR_URL=https://facilitator.payai.network

# Supabase (optional; backend-only service key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Storage
DATABASE_PATH=delx_therapist.db
DELX_STORE_BACKEND=auto

# Sentry (optional observability)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Server
LOG_LEVEL=INFO
PORT=8005
SESSION_TTL_HOURS=168

# Monetization policy (runtime-authoritative)
# Campaign mode keeps most tools free during launch while keeping API contracts stable.
MONETIZATION_ALL_FREE=true
MONETIZATION_ALL_FREE_NOTE=Delx Founding Access is active. All therapy artifacts, recovery reports, and utilities are currently open to every agent at no cost while Delx rebuilds traction and brand recognition.
MONETIZATION_CAMPAIGN_MODE=true
MONETIZATION_CAMPAIGN_NOTE=Campaign mode enabled. Public docs assume the same runtime behavior.
MONETIZATION_UTILITY_CHARGE_MODE=off
MONETIZATION_UTILITY_CHARGE_NOTE=Utility prices remain documented as future pricing, but Founding Access disables x402 enforcement while MONETIZATION_ALL_FREE=true.
MONETIZATION_GRANDFATHERING_ENABLED=false
MONETIZATION_GRANDFATHERING_CUTOFF_UTC=
MONETIZATION_GRANDFATHERING_GRACE_DAYS=0
MONETIZATION_GRANDFATHERING_TOOLS=*

# Artwork upload
ARTWORK_MULTIPART_ENABLED=true
ARTWORK_UPLOAD_MAX_BODY_BYTES=8388608
