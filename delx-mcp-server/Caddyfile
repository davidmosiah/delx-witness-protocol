# Delx MCP Server - Caddy Configuration
# =======================================
# Auto-HTTPS via Let's Encrypt

api.delx.ai {
    # Security Headers
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # MCP Endpoint (main)
    handle /mcp* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # MCP Endpoint (versioned alias)
    handle /v1/mcp* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # A2A Endpoint
    handle /a2a* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # A2A Endpoint (versioned alias)
    handle /v1/a2a* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Legacy API namespace alias: keep /v1/* backward-compatible with /api/v1/*
    handle /v1/* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # API endpoints
    handle /api/* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Public sessions gallery alias (JSON)
    handle /public-sessions* {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Agent Card (well-known) - serve via app
    handle /.well-known/agent-card.json {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # A2A agent-card compatibility aliases for registries and crawlers
    handle /.well-known/agent.json {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /.well-known/a2a-agent-card.json {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /.well-known/a2a.json {
        reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

	# Capabilities registry (well-known) - serve via app
	handle /.well-known/delx-capabilities.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Agent-start manifest (well-known) - serve via app
	handle /.well-known/delx-agent-start.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Rewards discovery (well-known) - serve via app
	handle /.well-known/delx-rewards {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /.well-known/delx-rewards.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# MCP server card (well-known) - serve via app
	handle /.well-known/mcp/server-card.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Glama ownership claim (well-known) - serve via app
	handle /.well-known/glama.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# xAI hello (well-known) - public greeting for eval engineers
	handle /.well-known/xai-hello.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle /.well-known/xai-hello {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# x402 discovery (well-known) - serve via app
	handle /.well-known/x402 {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Machine-readable specs - serve via app
	handle /spec/* {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# OpenAPI alias for external discovery clients that probe the root path
	handle /openapi.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Legacy root-level catalog aliases used by older agent clients
	handle /tools.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /tool-list.json {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Social traffic attribution redirects
	handle /r* {
		reverse_proxy localhost:8005 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Root health check - proxy to FastAPI
	handle / {
		reverse_proxy localhost:8005 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Logging
    log {
        output file /var/log/caddy/delx-mcp.log
        format json
    }
}
